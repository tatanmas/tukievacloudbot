# Copy to .env and set values. Do not commit .env.

# Gateway auth (generate new for clawd-clean)
CLAWDBOT_GATEWAY_TOKEN=your-gateway-token-here
# Extensión OpenClaw en Chrome: relay en el Mac en http://127.0.0.1:18792/ (no 18791). Mismo token que arriba.

# LLM
ANTHROPIC_API_KEY=sk-ant-your-key-here
NVIDIA_API_KEY=nvapi-your-key-here

# Notion (requerido para backlog/tareas/notas vía exec o skill)
NOTION_TOKEN=secret_xxxx
NOTION_API_KEY=secret_xxxx
NOTION_NOTES_DB_ID=xxxx
NOTION_ACTIONABLES_DB_ID=xxxx

# Google Places API (skill goplaces, opcional local-places) — misma key suele valer para Places API (New)
GOOGLE_PLACES_API_KEY=

# Slack (Socket Mode) — crear app en https://api.slack.com/apps ; ver docs/SLACK.md
# Tras definir: docker compose run --rm clawdbot-gateway clawdbot channels add --channel slack --use-env
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Tuki — API de integración LLM (solo lectura: snapshot, orders, etc.). SuperAdmin → API integración LLM.
# Ver skills/tuki-integration-api/SKILL.md. El token robusto solo en .env local / despliegue; no commitear.
TUKI_INTEGRATION_TOKEN=
# Opcional: si tu API vive en otro host que TUKI_API_BASE_URL, fija solo la integración:
# TUKI_INTEGRATION_BASE_URL=https://api.tuki.cl/api/v1
